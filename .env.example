# Copia este archivo a .env y completa los valores

# PostgreSQL local
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB?schema=public
DATABASE_URL="postgresql://dicaprev@localhost:5432/mi_app?schema=public"

# Auth.js
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambia-este-secreto"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-este-secreto"
NEXTAUTH_URL="http://localhost:3000"

# Password unica para login local por credenciales.
# El email debe existir en la tabla Usuario.
AUTH_DEV_PASSWORD="dev1234"
